<Window x:Class="Licorp_CombineCAD.Views.ReorderSheetsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Sheet Order"
        Height="520" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Drag selected sheets or use Up/Down to set export order."
                   Foreground="#D0D0D0"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <ListBox Grid.Row="1"
                 x:Name="ItemsListBox"
                 Background="#2D2D2D"
                 Foreground="White"
                 BorderBrush="#3E3E3E"
                 AllowDrop="True"
                 PreviewMouseLeftButtonDown="ItemsListBox_PreviewMouseLeftButtonDown"
                 PreviewMouseMove="ItemsListBox_PreviewMouseMove"
                 DragOver="ItemsListBox_DragOver"
                 Drop="ItemsListBox_Drop">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Index}" Foreground="#808080" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" TextWrapping="Wrap"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="Up" Width="74" Height="30" Margin="0,0,8,0" Click="MoveUp_Click"/>
                <Button Content="Down" Width="74" Height="30" Click="MoveDown_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Width="82" Height="30" Margin="0,0,8,0" Click="Ok_Click"/>
                <Button Content="Cancel" Width="82" Height="30" IsCancel="True"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
