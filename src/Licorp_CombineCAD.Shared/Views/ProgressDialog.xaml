<Window x:Class="Licorp_CombineCAD.Views.ProgressDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="clr-namespace:Licorp_CombineCAD.Views.Converters"
    mc:Ignorable="d"
    Title="Export Progress"
    Height="200" Width="450"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    Background="#1E1E1E"
    Foreground="#FFFFFF"
    Topmost="True">

    <Window.Resources>
        <converters:BoolToVisibleConverter x:Key="BoolToVisibleConverter"/>
        <converters:BoolToHiddenConverter x:Key="BoolToHiddenConverter"/>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#3E3E3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4E4E4E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
            Text="{Binding Phase}"
            FontSize="14" FontWeight="SemiBold"
            Foreground="#0078D4"
            Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1"
            Text="{Binding CurrentItem}"
            FontSize="12"
            Foreground="#CCCCCC"
            TextTrimming="CharacterEllipsis"
            Margin="0,0,0,12"/>

        <ProgressBar Grid.Row="2"
            Value="{Binding Percentage}"
            Maximum="100"
            Height="8"
            Background="#3E3E3E"
            Foreground="#0078D4"
            BorderThickness="0"/>

        <Grid Grid.Row="3" Margin="0,4,0,0">
            <TextBlock Text="{Binding ProgressText}"
                FontSize="11" Foreground="#808080"
                HorizontalAlignment="Right"/>
            <TextBlock Text="{Binding ElapsedTime, StringFormat='Elapsed: {0}'}"
                FontSize="11" Foreground="#808080"
                HorizontalAlignment="Left"/>
        </Grid>

        <TextBlock Grid.Row="4"
            Text="Export completed successfully!"
            FontSize="12"
            Foreground="#10B981"
            Visibility="{Binding Completed, Converter={StaticResource BoolToVisibleConverter}}"
            Margin="0,8,0,0"/>

        <Button Grid.Row="6"
            Content="Cancel"
            Command="{Binding CancelCommand}"
            Style="{StaticResource ModernButton}"
            HorizontalAlignment="Right"
            Margin="0,16,0,0"
            Visibility="{Binding Completed, Converter={StaticResource BoolToHiddenConverter}}"/>
    </Grid>
</Window>
