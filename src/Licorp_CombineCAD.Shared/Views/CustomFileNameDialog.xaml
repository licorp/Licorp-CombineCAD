<Window x:Class="Licorp_CombineCAD.Views.CustomFileNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom File Name"
        Height="430" Width="620"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="File name template" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <TextBox Grid.Row="1"
                 x:Name="TemplateTextBox"
                 TextChanged="TemplateTextBox_TextChanged"
                 Background="#2D2D2D"
                 Foreground="White"
                 BorderBrush="#3E3E3E"
                 Padding="8,6"
                 MinHeight="34"/>

        <GroupBox Grid.Row="2"
                  Header="Tokens"
                  Foreground="White"
                  BorderBrush="#3E3E3E"
                  Margin="0,14,0,0"
                  Padding="10">
            <UniformGrid Columns="2" Rows="3">
                <Button Content="{}{SheetNumber}" Tag="{}{SheetNumber}" Margin="4" Click="TokenButton_Click"/>
                <Button Content="{}{SheetName}" Tag="{}{SheetName}" Margin="4" Click="TokenButton_Click"/>
                <Button Content="{}{PaperSize}" Tag="{}{PaperSize}" Margin="4" Click="TokenButton_Click"/>
                <Button Content="{}{ProjectNumber}" Tag="{}{ProjectNumber}" Margin="4" Click="TokenButton_Click"/>
                <Button Content="{}{ProjectName}" Tag="{}{ProjectName}" Margin="4" Click="TokenButton_Click"/>
            </UniformGrid>
        </GroupBox>

        <Border Grid.Row="3"
                Background="#2D2D30"
                BorderBrush="#3E3E3E"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Margin="0,14,0,0">
            <StackPanel>
                <TextBlock Text="Preview" Foreground="#808080"/>
                <TextBlock x:Name="PreviewTextBlock"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="82" Height="30" Margin="0,0,8,0" Click="Ok_Click"/>
            <Button Content="Cancel" Width="82" Height="30" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
