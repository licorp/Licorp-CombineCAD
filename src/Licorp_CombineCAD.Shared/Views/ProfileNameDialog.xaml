<Window x:Class="Licorp_CombineCAD.Views.ProfileNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile Name"
        Height="170" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="White">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Prompt}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <TextBox Grid.Row="1"
                 x:Name="NameTextBox"
                 Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
                 Background="#2D2D2D"
                 Foreground="White"
                 BorderBrush="#3E3E3E"
                 Padding="8,6"
                 MinHeight="32"/>
        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="#FFB900"
                   TextWrapping="Wrap"
                   Margin="0,8,0,0"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="82" Height="30" Margin="0,0,8,0" Click="Ok_Click"/>
            <Button Content="Cancel" Width="82" Height="30" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
