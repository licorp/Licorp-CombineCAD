<Window x:Class="Licorp_CombineCAD.Views.LayerManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:Licorp_CombineCAD.Views.Converters"
        mc:Ignorable="d"
        Title="Layer Manager - CombineCAD"
        Height="300" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="#FFFFFF">

    <Window.Resources>
        <converters:StringToVisibleConverter x:Key="StringToVisibleConverter"/>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3E3E3E"/>
                    <Setter Property="Foreground" Value="#808080"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#3E3E3E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4E4E4E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E3E"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="DWG Layer Mapping"
                   FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <!-- Setup Selection -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Export Setup:" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <ComboBox ItemsSource="{Binding AvailableSetups}"
                      SelectedItem="{Binding SelectedSetup}"
                      Style="{StaticResource ModernComboBox}"
                      Width="250"/>
        </StackPanel>

        <!-- Description -->
        <Border Grid.Row="2"
                Background="#2D2D30"
                CornerRadius="4"
                Padding="12"
                Margin="0,0,0,16">
            <TextBlock TextWrapping="Wrap" TextAlignment="Justify" Foreground="#AAAAAA">
                Export layer mapping to a .txt file to share settings with your team,
                or import settings from another project. The file uses tab-delimited format:
                Category, SubCategory, LayerName, ColorId, Linetype.
            </TextBlock>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Foreground="#10B981"
                   FontSize="12"
                   Margin="0,0,0,16"
                   Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibleConverter}}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Export to File"
                    Command="{Binding ExportCommand}"
                    Style="{StaticResource ModernButton}"
                    Margin="0,0,8,0"/>
            <Button Content="Import from File"
                    Command="{Binding ImportCommand}"
                    Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>